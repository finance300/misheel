# Supabase — copy this file to ".env" and fill in your project's values.
# Find them in the Supabase dashboard: Project Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Finnhub market data (free key from https://finnhub.io) — powers the live ticker.
VITE_FINNHUB_API_KEY=your-finnhub-api-key
